<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.FpsBoostPro" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/neon_cyan</item>
        <item name="colorPrimaryVariant">@color/neon_cyan</item>
        <item name="colorOnPrimary">@color/black</item>

        <item name="colorSecondary">@color/neon_green</item>
        <item name="colorSecondaryVariant">@color/neon_green</item>
        <item name="colorOnSecondary">@color/black</item>

        <item name="android:colorBackground">@color/bg_root</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorError">@color/danger_red</item>

        <item name="android:statusBarColor">@color/bg_root</item>
        <item name="android:navigationBarColor">@color/bg_root</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">false</item>

        <item name="android:windowBackground">@color/bg_root</item>
        <item name="android:forceDarkAllowed" tools:targetApi="29">false</item>

        <item name="fontFamily">sans-serif</item>
        <item name="android:fontFamily">sans-serif</item>

        <item name="bottomNavigationStyle">@style/Widget.FpsBoostPro.BottomNav</item>
        <item name="materialButtonStyle">@style/Widget.FpsBoostPro.Button.Primary</item>
    </style>

    <style name="Widget.FpsBoostPro.BottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@color/bg_card</item>
        <item name="itemIconTint">@color/bottom_nav_color</item>
        <item name="itemTextColor">@color/bottom_nav_color</item>
        <item name="itemRippleColor">@color/cyan_glow_20</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="Widget.FpsBoostPro.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">@dimen/radius_lg</item>
        <item name="backgroundTint">@color/neon_cyan</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="rippleColor">@color/bg_card</item>
    </style>

    <style name="Widget.FpsBoostPro.Button.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">@dimen/radius_lg</item>
        <item name="strokeColor">@color/neon_cyan</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="android:textColor">@color/neon_cyan</item>
        <item name="rippleColor">@color/cyan_glow_20</item>
    </style>

    <style name="Text.Display" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="fontFamily">sans-serif-black</item>
        <item name="android:fontFamily">sans-serif-black</item>
    </style>

    <style name="Text.CardTitle" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Text.Metric.Value" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textColor">@color/neon_cyan</item>
        <item name="android:textStyle">bold</item>
        <item name="fontFamily">sans-serif-black</item>
        <item name="android:fontFamily">sans-serif-black</item>
    </style>

    <style name="Text.Metric.Label" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <style name="ShapeAppearance.FpsBoostPro.Card" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerSize">@dimen/radius_xl</item>
    </style>

</resources>
