<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_root"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="@dimen/spacing_xl">

    <ImageView
        android:id="@+id/img_stub_icon"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:src="@drawable/ic_bolt_small"
        app:tint="@color/neon_cyan"
        android:alpha="0.8"
        android:contentDescription="@null" />

    <TextView
        android:id="@+id/txt_stub_title"
        style="@style/Text.Display"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        android:textSize="20sp"
        tools:text="Games" />

    <TextView
        android:id="@+id/txt_stub_subtitle"
        style="@style/Text.Metric.Label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xs"
        android:gravity="center"
        android:text="@string/coming_soon" />

</LinearLayout>
