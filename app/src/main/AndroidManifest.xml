<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ===== Real, non-root permissions ===== -->

    <!-- List installed apps to power Game Center auto-detection -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <!-- Battery stats -->
    <uses-permission android:name="android.permission.BATTERY_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- Network state for Ping Booster / DNS Optimizer -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />

    <!-- VpnService is the only legitimate, non-root way to redirect DNS system-wide -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Gaming Overlay (draw FPS/perf HUD over games) -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Accessibility service powers: Background Apps list, per-app FPS overlay hook,
         and "close background apps" (user-initiated, not silent force-stop -
         normal apps cannot force-stop other apps without root/device-owner). -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- Post notifications (boost complete, thermal warning, etc.) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Vibration for haptic feedback on boost -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Storage Analyzer / Junk Cleaner (scoped storage safe, Android 11+ uses MANAGE_ALL_FILES only if user grants it) -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />

    <!-- Keep CPU awake briefly during an active boost/optimization pass -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:name=".FpsBoostApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FpsBoostPro"
        android:hardwareAccelerated="true"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.FpsBoostPro"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Real: draws the in-game performance HUD via SYSTEM_ALERT_WINDOW -->
        <service
            android:name=".core.monitor.OverlayService"
            android:foregroundServiceType="specialUse"
            android:exported="false">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Gaming performance overlay requested by the user" />
        </service>

        <!-- Real: VpnService-based DNS optimizer (the only non-root way to change
             system DNS routing on modern Android) -->
        <service
            android:name=".core.optimize.DnsVpnService"
            android:permission="android.permission.BIND_VPN_SERVICE"
            android:exported="false">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
        </service>

        <!-- Accessibility service: powers honest "Background Apps" detection and
             the optional per-app FPS counter overlay. Disabled until user opts in
             from Settings; never enabled silently. -->
        <service
            android:name=".core.monitor.FpsAccessibilityService"
            android:exported="false"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
